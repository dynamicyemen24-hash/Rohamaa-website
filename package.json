{
  "name": "rohamaa-website",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "منصة مؤسسة رحماء بينهم — منصة خيرية إنسانية تنموية متكاملة",
  "author": "Rohamaa Foundation",
  "license": "MIT",
  "homepage": "https://rohamaa.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/dynamicyemen24-hash/Rohamaa-website.git"
  },
  "bugs": {
    "url": "https://github.com/dynamicyemen24-hash/Rohamaa-website/issues"
  },
  "keywords": [
    "rohamaa",
    "charity",
    "humanitarian",
    "foundation",
    "react",
    "typescript",
    "vite",
    "supabase",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "seed:postgres": "node scripts/seed-postgres.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "analyze": "vite-bundle-analyzer",
    "prepare": "husky",
    "precommit": "lint-staged",
    "clean": "rm -rf dist node_modules",
    "validate": "pnpm typecheck && pnpm lint && pnpm build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },

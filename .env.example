# ============================================================
# Rohamaa Website Environment Configuration
# ============================================================

VITE_API_BASE_URL=https://api.rohamaa.org/api/v1
VITE_APP_NAME=منصة رحماء بينهم
VITE_NODE_ENV=production
VITE_APP_URL=https://rohamaa.org
VITE_ENV=production

# ============================================================
# Sanity.io Headless CMS Configuration
# ============================================================
# الحصول على المفاتيح: https://www.sanity.io/manage
VITE_SANITY_PROJECT_ID=xd0ohyiz
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-01-01
VITE_API_TIMEOUT=30000

# ⚠️ احصل على التوكن من: Sanity Studio → Settings → API → Tokens
VITE_SANITY_READ_TOKEN=YOUR_SANITY_READ_TOKEN

# ============================================================
# Supabase Configuration (Fallback Database)
# ============================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_SCHEMA=gs_website

# ============================================================
# PostgreSQL Neon (Legacy Support)
# ============================================================
# ⚠️ USE YOUR NEON CONNECTION STRING FROM: https://console.neon.tech
DATABASE_URL=YOUR_NEON_DATABASE_URL
PG_SCHEMA=gs_website

# ============================================================
# Feature Flags
# ============================================================
VITE_ENABLE_DEMO_AUTH=false
VITE_FORCE_LIVE_DB=true
VITE_USE_SANITY=true
VITE_ENABLE_PWA=true

# ============================================================
# API Security
# ============================================================
# Secret token for database API access (keep secure!)
DATABASE_API_SECRET=YOUR_SECURE_RANDOM_TOKEN

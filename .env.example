VITE_API_BASE_URL=https://api.rohamaa.org/api/v1
VITE_APP_NAME=منصة رحماء بينهم
VITE_NODE_ENV=production
VITE_APP_URL=https://rohamaa.org
VITE_ENV=production

# Supabase is used as the primary live CMS/database when configured.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_SCHEMA=gs_website

# Keep false in production unless this is a staging/demo deployment.
VITE_ENABLE_DEMO_AUTH=false

# Neon PostgreSQL (Postgres via Supabase-compatible pooler)
# Supabase client stores credentials in VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY.
DATABASE_URL=postgresql://neondb_owner:npg_S2vFTAquDK1g@ep-morning-silence-ahpz7wqf-pooler.c-3.us-east-1.aws.neon.tech/Rohamaa_website_db?sslmode=require&channel_binding=require
PG_SCHEMA=gs_website

# Optional: force data service to prefer Neon/Supabase tables when available
VITE_FORCE_LIVE_DB=true

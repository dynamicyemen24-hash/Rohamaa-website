{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist-node"
  },
  "include": ["vite.config.ts", "scripts/**/*.ts"]
}
# Production Environment Configuration
# ============================================
# This file should NEVER be committed with real values
# Use Vercel Environment Variables instead

# Application
VITE_APP_NAME=منصة رحماء بينهم
VITE_APP_URL=https://rohamaa.org
VITE_NODE_ENV=production
VITE_ENV=production

# API
VITE_API_BASE_URL=https://rohamaa.org/api/v1
VITE_API_TIMEOUT=30000

# Sanity CMS - Production
VITE_SANITY_PROJECT_ID=xd0ohyiz
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Supabase Auth (Production)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_SCHEMA=public

# Stripe Payments
VITE_STRIPE_PUBLIC_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

# PostgreSQL (Neon)
DATABASE_URL=YOUR_NEON_DATABASE_URL
PG_SCHEMA=public

# Feature Flags
VITE_ENABLE_DEMO_AUTH=false
VITE_FORCE_LIVE_DB=true
VITE_USE_SANITY=true
VITE_ENABLE_PWA=true
VITE_ENABLE_PAYMENTS=true